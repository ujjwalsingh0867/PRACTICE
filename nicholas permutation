#include <iostream>
#include <vector>
#include <algorithm>
#include <cmath>
 
using namespace std;
 
int main() {
    int n;
    cin >> n;
    
    int min_pos = 0, max_pos = 0;
    vector<int> a(n);
    
    for (int i = 0; i < n; i++) {
        cin >> a[i];
        if (a[i] == 1) min_pos = i;
        if (a[i] == n) max_pos = i;
    }
 
    // The maximum distance is the furthest any of the two 
    // extreme elements can get from either boundary.
    int res = max({
        abs(min_pos - 0), 
        abs(min_pos - (n - 1)), 
        abs(max_pos - 0), 
        abs(max_pos - (n - 1))
    });
 
    cout << res << endl;
    
    return 0;
}
